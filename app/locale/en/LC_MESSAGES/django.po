#: apps/common/exceptions.py:104
msgid "Объект используется другими записями и не может быть удалён."
msgstr "Object is referenced by other records and cannot be deleted."

#: apps/common/exceptions.py:119
msgid "Ошибка валидации данных."
msgstr "Data validation error."

#: apps/common/exceptions.py:136
msgid "Ошибка запроса."
msgstr "Request error."

#: apps/common/renderers.py:8 apps/common/renderers.py:30
msgid "Success"
msgstr "Success"

#: apps/common/renderers.py:9
msgid "Created successfully"
msgstr "Created successfully"

#: apps/common/renderers.py:10
msgid "Deleted successfully"
msgstr "Deleted successfully"

#: apps/notifications/views.py:60
msgid "Устройство не найдено."
msgstr "Device not found."

#: apps/notifications/views.py:112
msgid "Получатель не найден."
msgstr "Recipient not found."

#: apps/orders/exceptions.py:9
msgid "Недопустимый переход статуса заказа."
msgstr "Invalid order status transition."

#: apps/orders/exceptions.py:14
msgid "Роль не позволяет выполнить этот переход статуса."
msgstr "Your role cannot perform this status transition."

#: apps/orders/exceptions.py:19
msgid "Заказ отправлен и больше не может быть изменён."
msgstr "The order has been submitted and can no longer be edited."

#: apps/orders/exceptions.py:24
msgid "После подтверждения нельзя менять стороны, филиалы и стоимость."
msgstr "After confirmation, parties, branches and price cannot be changed."

#: apps/orders/exceptions.py:29
msgid "Заказ был изменён другим пользователем. Обновите данные."
msgstr "The order was modified by another user. Please refresh."

#: apps/orders/exceptions.py:34
msgid "Заказ уже оплачен."
msgstr "The order is already paid."

#: apps/orders/exceptions.py:39
msgid "Заказ должен содержать хотя бы одно грузовое место."
msgstr "The order must contain at least one package."

#: apps/orders/exceptions.py:44
msgid "Клиент может отменить заказ только до подтверждения."
msgstr "A client can cancel an order only before confirmation."

#: apps/users/exceptions.py:15
msgid "Неверный или истёкший код подтверждения."
msgstr "Invalid or expired confirmation code."

#: apps/users/exceptions.py:20
msgid "Код уже отправлен. Повторный запрос — через минуту."
msgstr "A code has already been sent. Try again in a minute."

#: apps/users/exceptions.py:25
msgid "Неверный телефон или пароль."
msgstr "Invalid phone or password."

#: apps/users/exceptions.py:31
msgid "Пользователь заблокирован."
msgstr "User is blocked."

#: apps/users/exceptions.py:36
msgid "Слишком много попыток входа. Повторите через 30 минут."
msgstr "Too many login attempts. Try again in 30 minutes."

#: apps/users/exceptions.py:41
msgid "Недействительный refresh-токен."
msgstr "Invalid refresh token."

#: apps/users/exceptions.py:47
msgid "Сессия не найдена."
msgstr "Session not found."

#: apps/users/exceptions.py:52
msgid "Нельзя удалить или заблокировать последнего суперадминистратора."
msgstr "Cannot delete or block the last superadmin."

#: apps/users/exceptions.py:57
msgid "Нельзя заблокировать или удалить самого себя."
msgstr "You cannot block or delete yourself."

#: apps/users/exceptions.py:62
msgid "Назначение этой роли недоступно."
msgstr "Assigning this role is not allowed."

#: apps/users/otp.py:60
msgid "Превышено число попыток. Запросите новый код."
msgstr "Too many attempts. Request a new code."

#: apps/users/services.py:147
msgid "Вход заблокирован. Обратитесь к администратору."
msgstr "Login is blocked. Contact the administrator."

#: apps/users/services.py:306
msgid "Текущий пароль указан неверно."
msgstr ""
